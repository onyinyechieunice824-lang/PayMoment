rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: name, phoneNumber, payMomentId, balances, accountNumber, tier, verification, transactions, beneficiaries, paymentLinks, momentPoints, investments, badges, transactionPin, cards, savings
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Basic validation for user profile
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'payMomentId', 'balances', 'accountNumber']) &&
             data.name is string && data.name.size() < 100 &&
             data.payMomentId is string && data.payMomentId.size() < 50 &&
             data.balances is map &&
             data.accountNumber is string && data.accountNumber.size() == 10;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read and write their own profile
      allow read: if isOwner(userId);
      
      // Allow creation if the user is the owner
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Allow updates if the user is the owner
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.accountNumber == resource.data.accountNumber;

      // Subcollections (if any)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Global transactions (if used)
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
